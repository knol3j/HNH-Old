{
  "name": "armageddon-pool",
  "version": "1.0.0",
  "description": "ARMgeddon Mining Pool - PhoneProof Algorithm",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:phoneproof": "node phoneproof-pool-server.js",
    "dev": "nodemon server.js",
    "dev:phoneproof": "nodemon phoneproof-pool-server.js",
    "test": "python phoneproof.py",
    "deploy": "pm2 start phoneproof-pool-server.js --name phoneproof-pool",
    "stop": "pm2 stop phoneproof-pool",
    "restart": "pm2 restart phoneproof-pool",
    "logs": "pm2 logs phoneproof-pool"
  },
  "keywords": [
    "mining",
    "pool",
    "mobile",
    "ARM",
    "cryptocurrency",
    "phoneproof",
    "battery-optimized",
    "blockchain"
  ],
  "author": "ARMgeddon Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "ws": "^8.14.2",
    "cors": "^2.8.5",
    "uuid": "^9.0.1",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "compression": "^1.7.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "pm2": "^5.3.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "config": {
    "phoneproof": {
      "port": 3003,
      "wsPort": 3004,
      "algorithm": "PhoneProof",
      "poolFee": 1.5,
      "blockTime": 30000,
      "difficultyAdjustment": 120000
    }
  }
}