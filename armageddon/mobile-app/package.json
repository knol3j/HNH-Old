{
  "name": "armageddon-mobile-miner",
  "version": "1.0.0",
  "description": "ARMgeddon Mobile Miner - Mine HNH tokens on your phone",
  "main": "App.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:android": "eas build --platform android --profile preview",
    "build:ios": "eas build --platform ios --profile development",
    "build:apk": "eas build --platform android --profile preview",
    "build:ipa": "eas build --platform ios --profile development",
    "build:both": "eas build --platform all --profile preview",
    "build:production": "eas build --platform all --profile production",
    "builds:list": "eas build:list",
    "builds:download": "echo 'Use: eas build:list to get download URLs'",
    "submit:android": "eas submit --platform android",
    "submit:ios": "eas submit --platform ios",
    "eject": "expo eject"
  },
  "dependencies": {
    "@expo/webpack-config": "^19.0.0",
    "@react-native-async-storage/async-storage": "~2.0.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/stack": "^7.0.0",
    "expo": "~52.0.0",
    "expo-battery": "~7.0.0",
    "expo-constants": "~17.0.0",
    "expo-crypto": "~14.0.0",
    "expo-dev-client": "~5.0.0",
    "expo-device": "~7.0.0",
    "expo-linear-gradient": "~14.0.0",
    "expo-notifications": "~0.29.0",
    "expo-secure-store": "~14.0.0",
    "expo-status-bar": "~2.0.0",
    "expo-build-properties": "~0.13.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.0",
    "react-native-safe-area-context": "~4.12.0",
    "react-native-screens": "~4.3.0",
    "react-native-svg": "~15.8.0",
    "react-native-web": "~0.19.13"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@expo/cli": "^0.22.0",
    "eas-cli": "^16.23.0"
  },
  "private": true,
  "expo": {
    "install": {
      "exclude": [
        "react-native-safe-area-context"
      ]
    }
  }
}