{
  "name": "armageddon-mobile-miner",
  "version": "1.0.0",
  "description": "ARMgeddon Mobile Miner - Mine HNH tokens on your phone",
  "main": "App.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:android": "eas build --platform android --profile preview",
    "build:ios": "eas build --platform ios --profile development",
    "build:apk": "eas build --platform android --profile preview",
    "build:ipa": "eas build --platform ios --profile development",
    "build:both": "eas build --platform all --profile preview",
    "build:production": "eas build --platform all --profile production",
    "builds:list": "eas build:list",
    "builds:download": "echo 'Use: eas build:list to get download URLs'",
    "submit:android": "eas submit --platform android",
    "submit:ios": "eas submit --platform ios",
    "eject": "expo eject"
  },
  "dependencies": {
    "@expo/webpack-config": "^18.0.0",
    "@react-native-async-storage/async-storage": "1.18.2",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/stack": "^6.3.20",
    "expo": "~55.0.0",
    "expo-battery": "~6.0.0",
    "expo-constants": "~14.4.2",
    "expo-crypto": "~12.4.1",
    "expo-dev-client": "~2.4.13",
    "expo-device": "~5.4.0",
    "expo-linear-gradient": "~12.3.0",
    "expo-notifications": "^0.32.12",
    "expo-secure-store": "~12.3.1",
    "expo-status-bar": "~1.6.0",
    "expo-build-properties": "~0.12.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.81.4",
    "react-native-safe-area-context": "4.6.3",
    "react-native-screens": "~3.22.0",
    "react-native-svg": "13.9.0",
    "react-native-web": "~0.19.6"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@expo/cli": "^54.0.11",
    "eas-cli": "^16.23.0"
  },
  "private": true,
  "expo": {
    "install": {
      "exclude": [
        "react-native-safe-area-context"
      ]
    }
  }
}