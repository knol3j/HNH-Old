{
  "name": "hashnhedge-gui-miner",
  "version": "2.0.0",
  "description": "HashNHedge GUI Mining Client - Easy-to-use desktop miner",
  "main": "src/main.js",
  "author": "HashNHedge Team",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "npm run build:windows && npm run build:linux && npm run build:macos",
    "build:windows": "electron-builder --windows",
    "build:linux": "electron-builder --linux",
    "build:macos": "electron-builder --mac",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.hashnhedge.miner",
    "productName": "HashNHedge Miner",
    "copyright": "Copyright © 2025 HashNHedge",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/logo.ico",
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "category": "Utility",
      "icon": "assets/logo.png",
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.utilities",
      "icon": "assets/logo.png",
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HashNHedge Miner"
    }
  },
  "dependencies": {
    "axios": "^1.12.2",
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1"
  }
}
