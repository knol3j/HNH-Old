# ============================================
# HashNHedge Production Environment Template
# ============================================
# Copy this to your deployment platform's environment variables
# Generate secrets with: openssl rand -hex 32

# ============================================
# CRITICAL - MUST SET THESE
# ============================================

# Node Environment
NODE_ENV=production

# Database (from Neon, Railway, or other PostgreSQL provider)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@host:5432/database?sslmode=require

# Secrets (MUST be 32+ characters, use: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
SESSION_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
ADMIN_API_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# ============================================
# APPLICATION CONFIGURATION
# ============================================

# API Server
API_PORT=10000
PORT=10000

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=https://hashnhedge.com,https://www.hashnhedge.com

# Base URLs
BASE_URL=https://hashnhedge.com
PORTAL_URL=https://hashnhedge.com/hnh-vendor-portal

# ============================================
# BLOCKCHAIN & WALLET
# ============================================

# Solana Configuration
SOLANA_NETWORK=mainnet-beta
OFFICIAL_WALLET_ADDRESS=GCKbEgD4VSLtkwt57At7pWscaxaQ2gBZtTQE2hqr3Yrc

# Pool Configuration
POOL_ADDRESS=YOUR_POOL_WALLET_ADDRESS_HERE
POOL_FEE_AI=0.30
POOL_FEE_MINING=0.03
MIN_PAYOUT=0.01

# ============================================
# POOL SERVER CONFIGURATION (hybrid-pool)
# ============================================

# Stratum Server
STRATUM_PORT=3333
STRATUM_HOST=0.0.0.0

# WebSocket
WS_PORT=8081

# ============================================
# AUTHENTICATION (Optional - Stack Auth)
# ============================================

# Stack Authentication (if using)
NEXT_PUBLIC_STACK_PROJECT_ID=
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=
STACK_SECRET_SERVER_KEY=

# ============================================
# EXTERNAL SERVICES (Optional)
# ============================================

# Neon Database API (if using Neon)
NEON_API_ENDPOINT=

# AWS S3 (for backups, optional)
AWS_REGION=us-east-1
AWS_S3_BUCKET=hashnhedge-pool-backups
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# SendGrid (for email notifications, optional)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@hashnhedge.com

# ============================================
# SECURITY CONFIGURATION
# ============================================

# JWT
JWT_EXPIRES_IN=7d

# Password Hashing
BCRYPT_ROUNDS=12

# Password Requirements
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_SPECIAL=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_UPPERCASE=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# ============================================
# LOGGING & MONITORING
# ============================================

LOG_LEVEL=info

# ============================================
# DEPLOYMENT NOTES
# ============================================
#
# Render:
# - Set these in the Render dashboard under Environment
# - Use "Generate Value" for secrets (JWT_SECRET, etc.)
# - DATABASE_URL automatically provided by Neon integration
#
# Railway:
# - Use: railway variables set KEY="value"
# - Generate secrets: railway variables set JWT_SECRET="$(openssl rand -hex 32)"
# - DATABASE_URL from Railway PostgreSQL plugin
#
# Security Checklist:
# ✅ All secrets are 32+ characters
# ✅ DATABASE_URL uses SSL (sslmode=require)
# ✅ CORS origins are specific (not *)
# ✅ JWT_SECRET is unique and random
# ✅ SESSION_SECRET is different from JWT_SECRET
# ✅ ADMIN_API_KEY is secure and rotated regularly
#
# ============================================
