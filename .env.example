# HashNHedge Docker Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# PostgreSQL Database
# ============================================
POSTGRES_PASSWORD=your_strong_postgres_password_here

# ============================================
# HashiCorp Vault
# ============================================
VAULT_ROOT_TOKEN=your_vault_root_token_here

# ============================================
# AWS S3 Storage
# ============================================
AWS_REGION=us-east-1
AWS_S3_BUCKET=hashnhedge-vendor-documents
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here

# ============================================
# SendGrid Email
# ============================================
SENDGRID_API_KEY=your_sendgrid_api_key_here

# ============================================
# Security & Authentication
# ============================================
# CRITICAL: Change these in production! Use strong, random values
ADMIN_API_KEY=your_admin_api_key_here_change_in_production
SESSION_SECRET=your_session_secret_here_min_32_chars_random
JWT_SECRET=your_jwt_secret_here_min_32_chars_random
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Password requirements
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_SPECIAL=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_UPPERCASE=true

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# ============================================
# Neon Database (PostgreSQL)
# ============================================
# Neon REST API Endpoint (get from Neon dashboard)
NEON_API_ENDPOINT=https://your-project.apirest.region.aws.neon.tech/database/rest/v1
# PostgreSQL connection string (replace with actual credentials)
DATABASE_URL=postgresql://username:password@your-host.neon.tech/database?sslmode=require
# Connection pool settings
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ============================================
# Stack Auth (Neon DB Connection via Netlify)
# ============================================
NEXT_PUBLIC_STACK_PROJECT_ID=your_stack_project_id_here
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=your_stack_publishable_key_here
STACK_SECRET_SERVER_KEY=your_stack_secret_key_here

# ============================================
# Application URLs
# ============================================
BASE_URL=https://hashnhedge.com
PORTAL_URL=https://hashnhedge.com/hnh-vendor-portal

# ============================================
# Solana Blockchain Configuration
# ============================================
# CRITICAL: Set your official wallet address for receiving payments
OFFICIAL_WALLET_ADDRESS=your_solana_wallet_address_here
SOLANA_NETWORK=mainnet-beta
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# For devnet testing, use:
# SOLANA_NETWORK=devnet
# SOLANA_RPC_URL=https://api.devnet.solana.com

# Token configuration
TOKEN_MINT_ADDRESS=your_token_mint_address_here
TOKEN_DECIMALS=9
TOKEN_LAUNCHED=false

# ============================================
# Optional: Custom Configuration
# ============================================
NODE_ENV=production
PORT=10000
API_PORT=10000
# STRATUM_PORT=3333

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=https://hashnhedge.com,https://www.hashnhedge.com

# ============================================
# Pool Fee Configuration
# ============================================
POOL_FEE_AI=0.30
POOL_FEE_MINING=0.03
