# HashNHedge Docker Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# PostgreSQL Database
# ============================================
POSTGRES_PASSWORD=your_strong_postgres_password_here

# ============================================
# HashiCorp Vault
# ============================================
VAULT_ROOT_TOKEN=your_vault_root_token_here

# ============================================
# AWS S3 Storage
# ============================================
AWS_REGION=us-east-1
AWS_S3_BUCKET=hashnhedge-vendor-documents
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here

# ============================================
# SendGrid Email
# ============================================
SENDGRID_API_KEY=your_sendgrid_api_key_here

# ============================================
# Security & Authentication
# ============================================
ADMIN_API_KEY=your_admin_api_key_here
SESSION_SECRET=your_session_secret_here
JWT_SECRET=your_jwt_secret_here

# ============================================
# Neon Database (PostgreSQL)
# ============================================
# Neon REST API Endpoint (get from Neon dashboard)
NEON_API_ENDPOINT=https://your-project.apirest.region.aws.neon.tech/database/rest/v1
# PostgreSQL connection string (replace with actual credentials)
DATABASE_URL=postgresql://username:password@your-host.neon.tech/database?sslmode=require

# ============================================
# Stack Auth (Neon DB Connection via Netlify)
# ============================================
NEXT_PUBLIC_STACK_PROJECT_ID=your_stack_project_id_here
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=your_stack_publishable_key_here
STACK_SECRET_SERVER_KEY=your_stack_secret_key_here

# ============================================
# Application URLs
# ============================================
BASE_URL=https://hashnhedge.com
PORTAL_URL=https://hashnhedge.com/hnh-vendor-portal

# ============================================
# Optional: Custom Configuration
# ============================================
# NODE_ENV=production
# PORT=3334
# STRATUM_PORT=3333
# API_PORT=3335

# ============================================
# Pool Fee Configuration
# ============================================
POOL_FEE_AI=0.30
POOL_FEE_MINING=0.03
