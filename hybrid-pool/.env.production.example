# HashNHedge Production Environment Configuration

# Node Environment
NODE_ENV=production

# Server Configuration
STRATUM_PORT=3333
STRATUM_HOST=0.0.0.0
API_PORT=3334
API_HOST=0.0.0.0
ADMIN_API_KEY=your-secure-admin-api-key-here

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hashnhedge_pool
DB_USER=pool_user
DB_PASSWORD=your-secure-db-password-here
DB_SSL=true
DB_POOL_MIN=2
DB_POOL_MAX=10

# AWS S3 Configuration (for backups and logs)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
S3_BUCKET=hashnhedge-pool-data
S3_BACKUP_BUCKET=hashnhedge-pool-backups
S3_LOG_BUCKET=hashnhedge-pool-logs

# SendGrid Configuration (for email notifications)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@hashnhedge.com
SENDGRID_ADMIN_EMAIL=admin@hashnhedge.com

# Pool Configuration
POOL_FEE_AI=0.30
POOL_FEE_MINING=0.03
MIN_PAYOUT=0.01
PAYMENT_INTERVAL=86400000

# Mining Configuration
DEFAULT_DIFFICULTY=1000000
VARDIFF_MIN=100000
VARDIFF_MAX=10000000
VARDIFF_TARGET_TIME=15
VARDIFF_RETARGET_TIME=90
VARDIFF_VARIANCE=0.30

# AI Job Configuration
AI_JOB_CHECK_INTERVAL=5000
MINING_FALLBACK_DELAY=10000
MAX_JOB_SWITCH_PER_HOUR=12

# Redis Configuration (optional, for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=0

# Monitoring & Analytics
ENABLE_MONITORING=true
METRICS_INTERVAL=60000
ENABLE_PROMETHEUS=true
PROMETHEUS_PORT=9090

# Security
JWT_SECRET=your-jwt-secret-key-here
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100
ENABLE_IP_WHITELIST=false
IP_WHITELIST=127.0.0.1,10.0.0.0/8

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
ENABLE_FILE_LOGGING=true
LOG_DIR=/var/log/hashnhedge
ENABLE_S3_LOGGING=true
LOG_ROTATION_SIZE=100M
LOG_ROTATION_COUNT=10

# Blockchain Configuration (Solana)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_NETWORK=mainnet-beta
TOKEN_MINT_ADDRESS=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
PAYMENT_WALLET_PRIVATE_KEY=your-wallet-private-key-base58

# Health Checks
HEALTH_CHECK_INTERVAL=30000
ENABLE_AUTO_RESTART=true
MAX_RESTART_ATTEMPTS=3

# Performance Tuning
UV_THREADPOOL_SIZE=128
NODE_OPTIONS=--max-old-space-size=4096
CLUSTER_WORKERS=auto

# Feature Flags
ENABLE_AI_JOBS=true
ENABLE_MINING_FALLBACK=true
ENABLE_DYNAMIC_FEES=false
ENABLE_AUTO_PAYOUTS=true
ENABLE_EMAIL_NOTIFICATIONS=true
