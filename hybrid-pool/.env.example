# HashNHedge Hybrid Pool - Render Environment Variables
# Copy this to .env for local development

# ========== NODE ENVIRONMENT ==========
NODE_ENV=production

# ========== STRATUM SERVER ==========
STRATUM_PORT=3333
STRATUM_HOST=0.0.0.0

# ========== ADMIN API ==========
# Render will set PORT automatically for HTTP traffic
# PORT=10000

# IMPORTANT: ADMIN_API_KEY must be at least 32 characters in production
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# For development, minimum 10 characters is allowed
ADMIN_API_KEY=your-secure-32-character-api-key-here-change-this-value-now

# ========== POOL FEES ==========
POOL_FEE_AI=0.30
POOL_FEE_MINING=0.03
MIN_PAYOUT=0.01

# ========== DATABASE (PostgreSQL) ==========
# Render provides this automatically if you add a PostgreSQL database
DATABASE_URL=postgresql://user:password@host:5432/hashnhedge_pool

# ========== AWS S3 (Backups) ==========
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=hashnhedge-pool-backups

# ========== SENDGRID (Email Notifications) ==========
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@hashnhedge.com

# ========== OPTIONAL SETTINGS ==========
# AI Job Check Interval (ms)
AI_JOB_CHECK_INTERVAL=5000

# Mining Fallback Delay (ms)
MINING_FALLBACK_DELAY=10000

# Max Job Switches Per Hour
MAX_JOB_SWITCH_PER_HOUR=12

# Payment Interval (ms, default 24 hours)
PAYMENT_INTERVAL=86400000
