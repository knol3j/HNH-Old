{
  // ================================================================
  // HashNHedge Multi-Coin Miner Configuration
  // Enhanced with realtime logging and wallet addresses
  // ================================================================

  // ============ MAIN POOL CONFIGURATION ============
  // Primary mining pool (RVN - Ravencoin with Flypool)
  "pools": [
    {
      "user": "YOUR_RVN_WALLET_ADDRESS_HERE",  // <-- ENTER YOUR RAVENCOIN WALLET
      "url": "stratum+tcp://stratum-ravencoin.flypool.org:3333",
      "pass": "x",
      "worker": "%HOSTNAME%_hnhrig"
    },
    {
      "user": "YOUR_RVN_WALLET_ADDRESS_HERE",  // <-- FAILOVER: 2miners
      "url": "stratum+tcp://rvn.2miners.com:6060",
      "pass": "x",
      "worker": "%HOSTNAME%_hnhrig"
    },
    {
      "user": "YOUR_RVN_WALLET_ADDRESS_HERE",  // <-- FAILOVER: Ravenminer
      "url": "stratum+tcp://stratum.ravenminer.com:3838",
      "pass": "x",
      "worker": "%HOSTNAME%_hnhrig"
    }
  ],

  // ============ DUAL MINING (OPTIONAL) ============
  // Uncomment to enable dual mining with a second algorithm
  // "dual-algo": "blake3",  // ALPH (Alephium)
  // "dual-algo-mode": "a12:r10",

  // Secondary pool for dual mining
  // "pools2": [
  //   {
  //     "user": "YOUR_ALPH_WALLET_ADDRESS_HERE",  // <-- ENTER YOUR ALEPHIUM WALLET
  //     "url": "stratum+tcp://alph-pool.example.com:3030",
  //     "pass": "x",
  //     "worker": "%HOSTNAME%_hnhrig_alph"
  //   }
  // ],

  // ============ ALGORITHM SETTINGS ============
  "algo": "kawpow",  // RVN algorithm
  "coin": "rvn",     // Helps avoid DAG rebuilds

  // ============ GPU CONFIGURATION ============
  "devices": "0",              // Use all GPUs (remove to use all)
  "intensity": 22,             // GPU intensity (8-25, higher = more power)
  "kernel": 0,                 // Auto-tune kernel (0 = auto)
  "gpu-init-mode": 0,          // Parallel GPU init
  "dag-build-mode": 0,         // Auto DAG build

  // ============ LOGGING & MONITORING ============
  "log-path": "logs/hashnhedge-miner.log",  // Log file location
  "protocol-dump": true,       // ENABLE PROTOCOL LOGGING (detailed stratum communication)
  "no-color": false,           // Keep colors in terminal
  "no-hashrate-report": false, // Show hashrate reports
  "hashrate-avr": 60,          // Hashrate averaging window (seconds)

  // ============ API & MONITORING ============
  "api-bind-http": "127.0.0.1:4067",  // HTTP API endpoint
  "api-https": false,
  "api-key": "",                       // Optional API key for security
  "api-read-only": false,

  // JSON API (for HashNHedge integration)
  "json-response": true,               // Enable JSON responses

  // ============ CONNECTION SETTINGS ============
  "retries": 5,                // Connection retry attempts
  "retry-pause": 10,           // Pause between retries (seconds)
  "timeout": 300,              // Max time without ping (seconds)
  "keep-gpu-busy": true,       // Keep mining during connection loss

  // ============ WORKER IDENTIFICATION ============
  "worker": "hashnhedge_worker_01",  // Default worker name

  // ============ PERFORMANCE SETTINGS ============
  "low-load": 0,               // Low load mode (0 = disabled)
  "mt": 4,                     // Number of mining threads per GPU
  "temperature-limit": 85,     // Auto-shutdown if GPU exceeds this temp
  "temperature-start": 60,     // Resume mining when temp drops below this

  // ============ LHR SETTINGS (for LHR cards) ============
  "lhr-tune": -1,              // -1 = auto, 0 = disabled, 74-95 = manual tune
  "lhr-autotune-mode": "full", // full = auto-adjust both up and down
  "lhr-autotune-step-size": 0.1,
  "lhr-low-power": 0,          // 0 = disabled, 1 = enable for lower power

  // ============ ADDITIONAL WALLET ADDRESSES ============
  // Copy this section and modify for different coins

  // --- ETHEREUM CLASSIC (ETC) ---
  // "algo": "etchash",
  // "coin": "etc",
  // "pools": [{"user": "YOUR_ETC_WALLET_HERE", "url": "stratum+tcp://etc.2miners.com:1010", "pass": "x"}]

  // --- ERGO (ERG) ---
  // "algo": "autolykos2",
  // "coin": "ergo",
  // "pools": [{"user": "YOUR_ERGO_WALLET_HERE", "url": "stratum+tcp://ergo.2miners.com:8888", "pass": "x"}]

  // --- CONFLUX (CFX) ---
  // "algo": "octopus",
  // "coin": "cfx",
  // "pools": [{"user": "YOUR_CFX_WALLET_HERE", "url": "stratum+tcp://cfx.woolypooly.com:3094", "pass": "x"}]

  // --- FIRO (FIRO) ---
  // "algo": "firopow",
  // "coin": "firo",
  // "pools": [{"user": "YOUR_FIRO_WALLET_HERE", "url": "stratum+tcp://firo.2miners.com:8181", "pass": "x"}]

  // --- ALEPHIUM (ALPH) ---
  // "algo": "blake3",
  // "coin": "alph",
  // "pools": [{"user": "YOUR_ALPH_WALLET_HERE", "url": "stratum+tcp://eu.metapool.tech:20032", "pass": "x"}]

  // ============ WATCHDOG ============
  "watchdog": true,            // Enable watchdog
  "watchdog-exit-mode": 0,     // 0 = restart, 1 = exit

  // ============ AUTO UPDATES ============
  "autoupdate": false,         // Disable auto-updates for stability

  // ============ TELEMETRY ============
  "send-hashrate": true,       // Send hashrate to pool
  "hashrate-units": "M"        // Display units: M = MH/s, G = GH/s
}
